# Server
NODE_ENV=production
APP_URL=https://swipebetter.ai
PORT=5000
SWIPEBETTER_API_ORIGIN=https://api.swipebetter.ai

# Database
DATABASE_URL=postgres://user:password@host:5432/database

# Auth/session
SESSION_SECRET=replace-with-long-random-secret
JWT_SECRET=replace-with-long-random-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Email
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=noreply@swipebetter.ai

# AI providers
AI_INTEGRATIONS_OPENAI_API_KEY=replace_me
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
XAI_API_KEY=replace_me

# OAuth, if enabled
APPLE_CLIENT_ID=replace_me
APPLE_BUNDLE_ID=app.replit.swipebetter
GOOGLE_CLIENT_ID=replace_me

# Apple in-app purchases
APPLE_IAP_ISSUER_ID=replace_me
APPLE_IAP_KEY_ID=replace_me
APPLE_IAP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----"

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
